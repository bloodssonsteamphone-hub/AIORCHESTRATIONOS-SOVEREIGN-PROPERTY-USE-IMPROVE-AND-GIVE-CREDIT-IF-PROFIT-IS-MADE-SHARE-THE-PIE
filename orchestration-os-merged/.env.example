# Zo Orchestration OS — Environment Variables

# Ollama (Local - Free)
OLLAMA_HOST=http://localhost:11434

# OpenRouter (Free Tier with Paid Options)
OPENROUTER_API_KEY=your_openrouter_key_here

# Google Gemini (Free Tier with Quota)
GEMINI_API_KEY=your_gemini_key_here

# OpenAI (Paid - Explicit Only)
OPENAI_API_KEY=your_openai_key_here

# Groq (Free Tier)
GROQ_API_KEY=your_groq_key_here

# Server
PORT=3000
NODE_ENV=production

# Paths
WORKSPACE=/workspace
OUTPUT_DIR=./output
DATA_DIR=./data
